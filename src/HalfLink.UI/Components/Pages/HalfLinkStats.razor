@page "/l/{HalfLink}/stats"
@using HalfLink.UI.Components.Shared
@inject HalfLinkService HalfLinkService

@if (link is not null)
{
    <MudContainer MaxWidth="MaxWidth.Large" Class="mx-auto my-5">
        <MudText Typo="Typo.h4"
                 Class="overflow-x-hidden mb-3"
                 Style="text-overflow: ellipsis; text-wrap-mode: nowrap;">
            Stats for: @link.FullLink
        </MudText>
        <StatsDataGrid Stats="stats" />
    </MudContainer>
}

@code {
    [Parameter]
    public string HalfLink { get; set; } = string.Empty;

    private Link? link = default;
    private IEnumerable<LinkStat> stats = Enumerable.Empty<LinkStat>();

    protected override async Task OnParametersSetAsync()
    {
        link = await HalfLinkService.GetLink(HalfLink);
        stats = await HalfLinkService.GetStats(HalfLink);
        await base.OnParametersSetAsync();
    }
}
