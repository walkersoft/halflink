@page "/"
@using HalfLink.UI.Components.Shared

@inject NavigationManager Navigation
@inject HalfLinkService HalfLinkService

<PageTitle>HalfLink - URL Shortener</PageTitle>

<MudContainer MaxWidth="MaxWidth.Large">
    <MudGrid Justify="Justify.Center">
        <MudItem xs="12">
            <MudText Typo="Typo.h2" GutterBottom="true" Align="Align.Center" Style="margin-top: 50px;">Welcome to HalfLink!</MudText>
        </MudItem>
        <MudItem xs="12">
            <MudText Typo="Typo.h6" GutterBottom="true" Align="Align.Center">Enter a URL below to shorten it</MudText>
        </MudItem>
        <MudItem xs="12">
            <HalfLinkForm OnLinkCreated="HandleLinkCreated" />
        </MudItem>
        
        @if (createdLink is not null)
        {
            <MudItem xs="6">
                <MudStack AlignItems="AlignItems.Center" Class="mt-5">
                    <MudText Typo="Typo.h6" GutterBottom="true">Shortened URL</MudText>
                    <MudText>
                        <MudLink Href="@createdLinkUrl" Target="_blank" Class="d-flex align-center">
                            @createdLinkUrl
                            <MudIcon Icon="@Icons.Material.Filled.OpenInNew" Size="Size.Small" Class="ml-1" />
                        </MudLink>
                    </MudText>
                </MudStack>
            </MudItem>
            <MudItem xs="6">
                <MudStack AlignItems="AlignItems.Center" Class="mt-5">
                    <MudText Typo="Typo.h6" GutterBottom="true">Click Stats</MudText>
                    <MudText>
                        <MudLink Href="@statsUrl" Class="d-flex align-center">
                            @statsUrl
                        </MudLink>
                    </MudText>
                </MudStack>
            </MudItem>
            <MudItem xs="12">
                <StatsDataGrid Stats="initialStats" />
            </MudItem>
        }
    </MudGrid>
</MudContainer>

@code {
    private Link? createdLink;
    private string statsUrl = string.Empty;
    private string createdLinkUrl = string.Empty;
    private IEnumerable<LinkStat> initialStats = Enumerable.Empty<LinkStat>();

    private async Task HandleLinkCreated(Link link)
    {
        createdLink = link;
        createdLinkUrl = GetHalfLinkUrl(link);
        statsUrl = $"{createdLinkUrl}/stats";
        initialStats = await LoadInitialStats(link.HalfLink);
    }

    private string GetHalfLinkUrl(Link link) => $"{Navigation.BaseUri}l/{link.HalfLink}";
    private Task<IEnumerable<LinkStat>> LoadInitialStats(string halfLink) => HalfLinkService.GetStats(halfLink);
}
