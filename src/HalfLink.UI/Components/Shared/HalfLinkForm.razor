@using HalfLink.Data
@inject HalfLinkService HalfLinkService
@inject LocalLinkStore LocalLinkStore

<MudForm>
    <MudGrid>
        <MudItem xs="8">
            <MudTextField @bind-Value="targetUrl"
                          Variant="Variant.Outlined"
                          Label="URL to Shorten"
                          Required="true"
                          RequiredError="A URL to shorten is required"
                          Error="isError"
                          ErrorText="@errorMessage" />
        </MudItem>
        <MudItem xs="4">
            <MudTextField @bind-Value="description"
                          Variant="Variant.Outlined"
                          Label="Description (Optional)" />
        </MudItem>
        <MudItem xs="3" Class="mx-auto">
            <MudButton Variant="Variant.Filled"
                       Color="Color.Primary"
                       Size="Size.Large"
                       FullWidth="true"
                       OnClick="ShortenUrl">
                Shorten It!
            </MudButton>
        </MudItem>
    </MudGrid>
</MudForm>

@code {
    [Parameter]
    public EventCallback<Link> OnLinkCreated { get; set; }

    private string? description = null;
    private string targetUrl = string.Empty;
    private bool isError = false;
    private string errorMessage = string.Empty;

    private async Task ShortenUrl()
    {
        try
        {
            isError = false;
            errorMessage = string.Empty;

            var createdLink = await HalfLinkService.CreateLink(targetUrl, description);
            await OnLinkCreated.InvokeAsync(createdLink);
            await LocalLinkStore.AddLink(createdLink);
        }
        catch (ArgumentException e)
        {
            isError = true;
            errorMessage = e.Message;
        }
    }
}
